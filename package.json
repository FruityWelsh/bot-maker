{
  "name": "chatbot-operator",
  "version": "0.1.0-dev",
  "description": "Kubernetes-native chat bot management with automated account creation and lifecycle management",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:validation": "jest tests/schemas/validation.js",
    "test:tools": "jest tests/tools/",
    "test:all": "jest tests/",
    "lint": "npm run lint:yaml && npm run lint:markdown",
    "lint:yaml": "yamllint -c .yamllint.yaml .",
    "lint:markdown": "markdownlint -c .markdownlint.yaml .",
    "check:strategy": "node scripts/validation/check-strategy-chain.js",
    "validate:all": "npm test && npm run lint && npm run check:strategy"
  },
  "keywords": [
    "kubernetes",
    "operator",
    "chatbot",
    "slack",
    "matrix",
    "discord",
    "twilio",
    "crd",
    "gitops"
  ],
  "author": "Strategy Coder",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {
    "ajv": "^8.12.0",
    "jest": "^29.7.0",
    "markdownlint": "^0.30.0",
    "markdownlint-cli": "^0.37.0",
    "shellcheck": "^0.9.1",
    "yamllint": "^1.3.2",
    "yamllint-cli": "^0.3.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "**/tests/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "verbose": true,
    "testTimeout": 30000
  }
}