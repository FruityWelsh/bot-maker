{
  "$id": "https://github.com/FruityWelsh/bot-maker/tests/schemas/botcredential-crd.json",
  "title": "BotCredential CRD Schema",
  "description": "JSON Schema for validating BotCredential Custom Resource Definitions (CRDs)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^chatbot\\.operator\\/v1alpha1$",
      "description": "API version for BotCredential CRD"
    },
    "kind": {
      "type": "string",
      "pattern": "^BotCredential$",
      "description": "Kind of resource"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "spec": {
      "$ref": "#/$defs/botcredentialSpec"
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["name", "namespace"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "description": "Name of the BotCredential resource"
        },
        "namespace": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "description": "Namespace for the BotCredential resource"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Labels for the BotCredential resource"
        }
      }
    },
    "botcredentialSpec": {
      "type": "object",
      "required": ["chatBotRef", "type", "valueEncrypted", "encryptionAlgorithm"],
      "additionalProperties": false,
      "properties": {
        "chatBotRef": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to the ChatBot resource this credential belongs to"
        },
        "type": {
          "type": "string",
          "enum": ["apiToken", "apiKey", "password", "certificate", "sshKey"],
          "description": "Type of credential"
        },
        "valueEncrypted": {
          "type": "string",
          "minLength": 1,
          "description": "Encrypted credential value"
        },
        "encryptionAlgorithm": {
          "type": "string",
          "enum": ["AES-256-GCM", "AES-256-CBC", "RSA-2048", "RSA-4096"],
          "description": "Encryption algorithm used"
        },
        "expiresAt": {
          "type": "string",
          "format": "date",
          "description": "Expiration date of the credential"
        },
        "lastRotated": {
          "type": "string",
          "format": "date",
          "description": "When the credential was last rotated"
        },
        "rotationSchedule": {
          "type": "string",
          "pattern": "^[0-9]+[dhm]$",
          "description": "Rotation schedule (e.g., 30d, 1h, 60m)"
        }
      }
    }
  }
}