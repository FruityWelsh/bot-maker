<?xml version="1.0" encoding="UTF-8"?>
<model name="ChatBot Operator Enterprise Architecture" version="1.0.0" xmlns="http://www.archimatetool.com/xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <id>root</id>
  <elements>
    <element xsi:type="archimate:BusinessActor" id="platform-team" name="Platform Engineering Team">
      <documentation>Responsible for infrastructure setup, RBAC/ABAC backend integration</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" id="infrastructure-manager" name="Infrastructure Manager">
      <documentation>Manages infrastructure components</documentation>
    </element>
  </elements>
  <relationships>
    <relationship id="platform-assignment" source="platform-team" target="infrastructure-manager">
      <type>AssignmentRelationship</type>
    </relationship>
  </relationships>
</model>
