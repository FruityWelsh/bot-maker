{
  "apiVersion": "chatbot.operator/v1alpha1",
  "kind": "BotCredential",
  "metadata": {
    "name": "slack-token",
    "namespace": "default"
  },
  "spec": {
    "chatBotRef": "test-slack-bot",
    "type": "apiToken",
    "valueEncrypted": "encrypted-token-data",
    "encryptionAlgorithm": "AES-256-GCM",
    "expiresAt": "2026-12-31",
    "lastRotated": "2026-01-01",
    "rotationSchedule": "30d"
  }
}
